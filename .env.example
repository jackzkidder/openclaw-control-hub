# ─── Database ─────────────────────────────────────────────────────────────────
# Turso is required when deploying to Vercel (serverless — no local filesystem).
# Create a free database at https://turso.tech, then copy the URL and token.
# Local development falls back to SQLite at ./data/mission-control.db automatically.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── OpenClaw Gateway ─────────────────────────────────────────────────────────
# Pre-configure the gateway connection. You can also set these in the app's
# Settings page at runtime — no restart required.
# Must include the port. Use wss:// for TLS (required on Vercel).
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:8765
# OPENCLAW_API_KEY=your-gateway-api-key
