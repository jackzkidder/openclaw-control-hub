# Turso remote database (required on Vercel)
# Get these from https://turso.tech after creating a database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# OpenClaw Gateway (optional - configure in the app Settings page instead)
# GATEWAY_URL=wss://your-gateway.example.com
# GATEWAY_API_KEY=sk-...
